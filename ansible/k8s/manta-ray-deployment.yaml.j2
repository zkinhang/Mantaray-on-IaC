apiVersion: apps/v1
kind: Deployment
metadata:
  name: webrtc-sender-a-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: webrtc-sender-a
  template:
    metadata:
      labels:
        app: webrtc-sender-a
    spec:
      hostNetwork: true
      hostIPC: true
      dnsPolicy: ClusterFirstWithHostNet
      nodeSelector:
        ros2-hardware: rov-main
      containers:
      - name: webrtc-sender-a-container
        image: "{{ main_ros_image }}"
        args: ["python", "/ros2_ws/src/webrtc/webrtc_sender.py", "--device", "{{ path_a_camera }}", "--signaling", "ws://webrtc-signaling-service:9000?stream=rov", "--width", "{{ webrtc_main_width | default(1280) }}", "--height", "{{ webrtc_main_height | default(720) }}", "--fps", "{{ webrtc_main_fps | default(30) }}", "--bitrate", "{{ webrtc_main_bitrate | default(2500) }}", "--key-int", "{{ webrtc_main_key_int | default(30) }}"]
        securityContext:
          privileged: true
        volumeMounts:
        - name: camera-device
          mountPath: "{{ path_a_camera }}"
      volumes:
      - name: camera-device
        hostPath:
          path: "{{ path_a_camera }}"
---
