---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: thrusterboard-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: thrusterboard
  template:
    metadata:
      labels:
        app: thrusterboard
    spec:
      nodeSelector:
        ros2-hardware: rov-main
      hostNetwork: true
      hostIPC: true
      volumes:
      - name: serial-port
        hostPath:
          path: /dev
      - name: parameter-volume
        configMap:
          name: robot-parameters
      - name: thrusterboard-api-source
        hostPath:
          path: "{{ path_thrusterboard_api }}"
      containers:
      - name: thrusterboard-container
        image: "{{ main_ros_image }}" 
        command: ["/bin/bash", "-c"]

        args:
          - >
            source install/setup.bash && 
            ros2 launch /ros2_ws/src/launch_file/launch_thruster.py params_file:=/config/params.yaml
        securityContext:
          privileged: true
        volumeMounts:
        - name: serial-port
          mountPath: /dev
        - name: parameter-volume
          mountPath: /config
          readOnly: true
        - name: thrusterboard-api-source
          mountPath: "{{ path_thrusterboard_mounting }}"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: pid-system-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: pid-system
  template:
    metadata:
      labels:
        app: pid-system
    spec:
      volumes:
      - name: dev-input
        hostPath:
          path: "{{ path_imu }}"
      - name: parameter-volume
        configMap:
          name: robot-parameters
      nodeSelector:
        ros2-hardware: rov-main
      hostNetwork: true
      hostIPC: true
      containers:
      - name: pid-system-container
        image: "{{ main_ros_image }}"
        volumeMounts:
        - name: dev-input
          mountPath: "{{ path_imu }}"
        - name: parameter-volume
          mountPath: /config
          readOnly: true
        securityContext:
          privileged: true
        command: ["/bin/bash", "-c"]
        args:
          - "source /ros2_ws/install/setup.bash && ros2 run control_system_pkg pid_system_node --ros-args --params-file /config/params.yaml"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: microros-agent-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: microros-agent
  template:
    metadata:
      labels:
        app: microros-agent
    spec:
      nodeSelector:
        ros2-hardware: rov-camera
      hostNetwork: true
      hostIPC: true
      volumes:
      - name: serial-port-agent
        hostPath:
          path: /dev
      containers:
      - name: microros-agent-container
        image: "{{ microros_image }}"
        imagePullPolicy: Always
        securityContext:
          privileged: true
        volumeMounts:
        - name: serial-port-agent
          mountPath: /dev
        # sleep command to test
        # args: ["while true; do sleep 30; done;"]
        command: ["/bin/bash", "-c"]
        args:
          - >
            source install/setup.bash && 
            echo "Setting permissions for {{ path_microros_serial }}..." && 
            chmod 777 {{ path_microros_serial }} && 
            echo "Running esptool..." &&
            esptool --port {{ path_microros_serial }} run && 
            echo "Starting Micro-ROS Agent..." &&
            ros2 run micro_ros_agent micro_ros_agent serial --dev {{ path_microros_serial }}

