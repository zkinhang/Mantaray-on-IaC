# '{{ main_ros_image }}' and '{{ microros_image }}' are variables

apiVersion: apps/v1
kind: Deployment
metadata:
  name: controller-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: controller
  template:
    metadata:
      labels:
        app: controller
    spec:
      # Use host networking for ROS 2 discovery
      hostNetwork: true
      hostIPC: true
      # Ensure this pod runs ONLY on the PC
      nodeSelector:
        ros2-hardware: land-pc
      containers:
      - name: controller-container
        image: "{{ main_ros_image }}"
        args: ["ros2", "run", "controller_pkg", "joystick_reader"]
        # Grant privileges to access host devices
        securityContext:
          privileged: true
        volumeMounts:
        - name: dev-input
          mountPath: /dev/input
      volumes:
      - name: dev-input
        hostPath:
          path: /dev/input
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: receiver-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: receiver
  template:
    metadata:
      labels:
        app: receiver
    spec:
      hostNetwork: true
      hostIPC: true
      nodeSelector:
        ros2-hardware: land-pc

      volumes:
      - name: parameter-volume
        configMap:
          name: robot-parameters
      - name: thrusterboard-api-source
        hostPath:
          path: "{{ path_thrusterboard_api }}"

      containers:
      - name: receiver-container
        image: "{{ main_ros_image }}"

        command: ["/bin/bash", "-c"]
        args:
          - "source /ros2_ws/install/setup.bash && ros2 run receiver_pkg decomposer --ros-args --params-file /config/params.yaml"

        volumeMounts:
        - name: parameter-volume
          mountPath: /config
          readOnly: true
        - name: thrusterboard-api-source
          mountPath: "{{ path_thrusterboard_mounting }}"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: foxglove-bridge-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: foxglove-bridge
  template:
    metadata:
      labels:
        app: foxglove-bridge
    spec:
      hostNetwork: true
      hostIPC: true
      nodeSelector:
        ros2-hardware: land-pc
      containers:
      - name: foxglove-bridge-container
        image: "{{ main_ros_image }}"
        args: ["ros2", "launch", "foxglove_bridge", "foxglove_bridge_launch.xml", "port:=8765"]
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: rosbridge-server-deployment
  namespace: default
spec:
  replicas: 1
  selector:
    matchLabels:
      app: rosbridge-server
  template:
    metadata:
      labels:
        app: rosbridge-server
    spec:
      # hostNetwork is useful for simplicity in Mode A/B networking
      hostNetwork: true 
      nodeSelector:
        # Deploying on the same node as Foxglove for consistency
        ros2-hardware: land-pc 
      containers:
      - name: rosbridge-server-container
        image: "{{ main_ros_image }}"
        # Launching rosbridge_server specifically
        args: ["ros2", "launch", "rosbridge_server", "rosbridge_websocket_launch.xml", "delay_between_messages:=0.0"]
        ports:
        - containerPort: 9090
          name: websocket
---
