---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: http-streamer-a-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: http-streamer-a
  template:
    metadata:
      labels:
        app: http-streamer-a
    spec:
      hostNetwork: true
      nodeSelector:
        ros2-hardware: rov-main
      containers:
      - name: http-streamer-a-container
        image: "{{ main_ros_image }}"
        command: ["python3", "webrtc_streamer.py", "--device", "/dev/video0", "--port", "8080"]
        securityContext:
          privileged: true
        volumeMounts:
        - name: camera-device
          mountPath: "{{ path_a_camera }}"
      volumes:
      - name: camera-device
        hostPath:
          path: "{{ path_a_camera }}"
---
