apiVersion: apps/v1
kind: Deployment
metadata:
  name: thrusterboard-deployment
spec:
  replicas: 1
  selector:
    matchLabels:
      app: thrusterboard
  template:
    metadata:
      labels:
        app: thrusterboard
    spec:
      nodeSelector:
        ros2-hardware: rov-main
      hostNetwork: true
      hostIPC: true
      volumes:
      - name: serial-port
        hostPath:
          path: /dev
      - name: parameter-volume
        configMap:
          name: robot-parameters
      - name: thrusterboard-api-source
        hostPath:
          path: "{{ path_thrusterboard_api }}"
      containers:
      - name: thrusterboard-container
        image: "{{ main_ros_image }}" 
        command: ["/bin/bash", "-c"]
        args:
          - >
            source install/setup.bash && 
            ros2 launch /ros2_ws/src/launch_file/launch_thruster.py params_file:=/config/params.yaml
        env:
        - name: ROS_DOMAIN_ID
          value: "0"
        securityContext:
          privileged: true
        livenessProbe:
          exec:
            command:
            - /bin/bash
            - -c
            - "source /ros2_ws/install/setup.bash && ros2 topic echo /imu --once --timeout 2"
          initialDelaySeconds: 30
          periodSeconds: 15
          failureThreshold: 2
          timeoutSeconds: 4
        volumeMounts:
        - name: serial-port
          mountPath: /dev
        - name: parameter-volume
          mountPath: /config
          readOnly: true
        - name: thrusterboard-api-source
          mountPath: "{{ path_thrusterboard_mounting }}"
        livenessProbe:
          exec:
            command: ["/bin/bash", "-c", "source /ros2_ws/install/setup.bash && ros2 topic hz /imu | grep -v 'average rate: 0.000'"]
          initialDelaySeconds: 30
          periodSeconds: 15
          timeoutSeconds: 10
          successThreshold: 1
          failureThreshold: 3
---
