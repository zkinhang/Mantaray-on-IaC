[Unit]
Description=WebRTC signaling server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=REPO_DIR=/opt/mantaray/Mantaray-on-IaC
WorkingDirectory=${REPO_DIR}
ExecStart=/usr/bin/python3 ${REPO_DIR}/src/webrtc/signaling_server.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
