[Unit]
Description=WebRTC sender (aux camera)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=REPO_DIR=/opt/mantaray/Mantaray-on-IaC
WorkingDirectory=${REPO_DIR}
ExecStart=/usr/bin/python3 ${REPO_DIR}/src/webrtc/webrtc_sender.py --device /dev/video1 --signaling ws://127.0.0.1:9000?stream=rov-cam --width 640 --height 480 --fps 30 --bitrate 900 --key-int 30
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
